<group name="local,syslog,sshd,">
  <rule id="100001" level="5">
    <if_sid>5716</if_sid>
    <srcip>1.1.1.1</srcip>
    <description>sshd: authentication failed from IP 1.1.1.1.</description>
    <group>authentication_failed,pci_dss_10.2.4,pci_dss_10.2.5,</group>
  </rule>
</group>

<group name="portscan,scan,custom,">

  <!-- Override rule 4100 to give it a level so children can fire -->
  <rule id="100099" level="3">
    <if_sid>4100</if_sid>
    <match>PORTSCAN</match>
    <description>Firewall portscan event detected</description>
    <group>firewall,recon,</group>
  </rule>

  <rule id="100100" level="15" ignore="0">
    <if_sid>100099</if_sid>
    <match>PROTO=TCP</match>
    <description>Detected TCP SYN port scan via iptables log</description>
    <group>recon,pci_dss_11.4,</group>
  </rule>

  <rule id="100101" level="15" ignore="0">
    <if_sid>100099</if_sid>
    <match>PROTO=UDP</match>
    <description>Detected UDP port scan via iptables log</description>
    <group>recon,pci_dss_11.4,</group>
  </rule>

  <rule id="100102" level="15" ignore="0">
    <if_sid>100099</if_sid>
    <match>PROTO=ICMP</match>
    <description>Detected ICMP scan via iptables log</description>
    <group>recon,pci_dss_11.4,</group>
  </rule>

</group>

